# MSG Закупки — пример переменных окружения для docker-compose
#
# Скопировать в /srv/msg-zakupki/.env на VPS и заполнить реальными значениями.
# Этот файл (.env.example) безопасно коммитить — реальный .env в gitignore.

# ─── Имя проекта Docker Compose ──────────────────────────────────
# Critical: без этого volumes получат имена infra_* вместо msg-zakupki_*,
# что сломает backup-n8n.sh (он ищет volume msg-zakupki_n8n_data).
COMPOSE_PROJECT_NAME=msg-zakupki

# ─── Supabase (для app — этап 1+) ────────────────────────────────
# SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Service role key хранится в Docker secret, не в env:
# infra/secrets/supabase_service_role.txt

# ─── n8n version pin ─────────────────────────────────────────────
# Используется в docker-compose.yml для n8n image
# N8N_VERSION=1.70.0

# ─── Beget bot для Telegram-алертов ──────────────────────────────
# TELEGRAM_BOT_TOKEN=12345:AAAA...
# TELEGRAM_CHAT_ID=123456789

# ─── Backup retention overrides ──────────────────────────────────
# Локальный retention (дней) — backup-n8n.sh
# BACKUP_LOCAL_RETENTION_DAYS=7
# Удалённый retention в Yandex Disk
# BACKUP_REMOTE_RETENTION_DAYS=30
